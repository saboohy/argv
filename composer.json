{
    "name": "saboohy/argv",
    "type": "library",
    "keywords": ["php", "cli", "console", "argv"],
    "description": "A lightweight and developer-friendly PHP library for parsing command-line arguments.",
    "license": "MIT",
    "version": "1.0.0",
    "readme": "https://github.com/saboohy/argv/blob/main/README.md",
    "homepage": "https://github.com/saboohy/argv",
    "authors": [
        {
            "name": "Sabuhi Alizada",
            "role": "Developer",
            "email": "sabuhi.alizada@hotmail.com",
            "homepage": "https://github.com/saboohy"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Saboohy\\Argv\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Saboohy\\Argv\\Tests\\": "tests/"
        }
    }
}
